---
const { title, description } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | MyFamilyBank</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="https://myfamilybank.eu" class="logo">MyFamilyBank</a>
      <nav>
        <a href="/">Blog</a>
        <a href="https://myfamilybank.eu" class="btn-cta">Open app</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="container">
      <p>© {new Date().getFullYear()} MyFamilyBank.</p>
      <nav><a href="https://myfamilybank.eu">MyFamilyBank</a></nav>
    </div>
  </footer>
</body>
</html>
